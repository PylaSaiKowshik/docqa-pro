# ── DocQA-Pro Environment Configuration ──────────────────────────────────────

# [Optional] OpenAI API key — used as LLM fallback and by RAGAS eval scorer
# Leave blank to use Flan-T5 locally (no API key required)
OPENAI_API_KEY=

# FastAPI backend URL (used by Streamlit frontend)
BACKEND_URL=http://localhost:8000

# ── Model settings ────────────────────────────────────────────────────────────
# Options: "google/flan-t5-base", "google/flan-t5-large", "google/flan-t5-xl"
LLM_MODEL_NAME=google/flan-t5-large

# Sentence-transformer model for embeddings
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=102   # ~20% of chunk_size

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
RRF_K=60            # RRF constant (rank fusion denominator offset)

# ── Storage paths ─────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/vectorstores/faiss_index
CHROMA_PERSIST_PATH=data/vectorstores/chroma
BM25_PICKLE_PATH=data/vectorstores/bm25.pkl
UPLOAD_DIR=data/uploads
EVAL_RESULTS_PATH=data/eval_results.json
